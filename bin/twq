#!/usr/bin/env python3
"""Bootstrap and run the tw_quant CLI."""

from __future__ import annotations

import sys
import sysconfig
from pathlib import Path


def _add_paths_from_pth() -> None:
    purelib = sysconfig.get_path("purelib")
    if not purelib:
        return

    site_packages = Path(purelib)
    for pth_path in sorted(site_packages.glob("*.pth")):
        try:
            lines = pth_path.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue

        for line in lines:
            candidate_text = line.strip()
            if (
                not candidate_text
                or candidate_text.startswith("#")
                or candidate_text.startswith("import ")
            ):
                continue

            candidate_path = Path(candidate_text).expanduser()
            if not candidate_path.is_absolute():
                candidate_path = (pth_path.parent / candidate_path).resolve()
            if candidate_path.exists():
                candidate = str(candidate_path)
                if candidate not in sys.path:
                    sys.path.insert(0, candidate)


def _add_paths_from_project_ancestors() -> None:
    script_path = Path(__file__).resolve()
    for ancestor in script_path.parents:
        src_root = ancestor / "src"
        package_root = src_root / "tw_quant"
        if package_root.is_dir():
            candidate = str(src_root)
            if candidate not in sys.path:
                sys.path.insert(0, candidate)
            return


def _resolve_run():
    try:
        from tw_quant.cli import run
    except ModuleNotFoundError as error:
        if error.name != "tw_quant":
            raise
        _add_paths_from_pth()
        _add_paths_from_project_ancestors()
        from tw_quant.cli import run
    return run


if __name__ == "__main__":
    run = _resolve_run()
    sys.exit(run())
